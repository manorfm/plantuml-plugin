@startuml
' === Variante C: !theme plain + skinparam de layout (nodesep, ranksep, …) ===
' Visão compacta: examples/architecture-overview.puml
' Igual em topologia a architecture.puml (diagrama denso no canvas).
' docs/architecture-diagrams.md
!theme plain
skinparam shadowing false
skinparam roundcorner 10
skinparam defaultFontName Verdana

skinparam nodesep 100
skinparam ranksep 85
skinparam packagePadding 26
skinparam componentPadding 14
skinparam linetype ortho
skinparam ArrowThickness 1

title plantuml-plugin-manorfm v0.11.10 — plain + layout manual (diagrama denso)

left to right direction

package "Composição (entrada)" {
  component [extension.ts] as EXT <<TypeScript>>
}

package "Funcionalidades (UI)" {
  component [plantumlStatusBar.ts] as SBR
  component [plantumlModeCodeLens.ts] as CL
  component [plantumlFormatting.ts] as FMT
}

package "Configuração" {
  component [plantumlConfig.ts] as CFG
  component [plantumlConnectionSettings.ts] as PCS
}

package "Utilities" {
  component [abortSignal.ts] as AB
  component [debounce.ts] as DB
  component [plantumlEditor.ts] as PUE
}

package "Session registry" {
  component [plantumlEditorSessionRegistry.ts] as ESR
  component [plantumlViewMode.ts] as VM
}

package "Custom editor" {
  component [plantumlCustomEditorProvider.ts] as CEP
  component [customEditorHtml.ts] as CEH
  component [diagramSvgCache.ts] as DSC
}

package "Preview (fragments)" {
  component [html.ts] as HTML
}

package "Domínio PlantUML\n(rede + texto + render + export)" as DOM {
  package "Rendering" {
    component [renderPipeline.ts] as RP
  }
  package "Rede e texto" {
    component [serverClient.ts] as SC
    component [expandIncludes.ts] as INC
    component [sourceTransform.ts] as ST
  }
  component [exportDiagram.ts] as EXP
}

note bottom of RP
  Hub plantuml/rendering/*
  (analyzeDiagram, themes, preamble, SVG)
end note

cloud "PlantUML server\n(HTTP)" as SRV #LightBlue

EXT --> CEP : custom editor
EXT --> SBR
EXT --> CL
EXT --> FMT
EXT --> EXP : comandos
EXT --> CFG : invalidate cache

CFG --> PCS : normalize settings

SBR --> CFG
SBR --> ESR
CL --> CFG
CL --> PUE
FMT --> ESR
FMT --> PUE

CEP --> CEH : webview shell
CEP --> INC : !include
CEP --> SC : fetch SVG
CEP --> HTML : mount
CEP --> CFG
CEP --> RP : prepare + enhance
CEP --> DSC : cache
CEP --> DB : debounce refresh
CEP --> ESR : register session
CEP --> PUE
CEP --> VM : types

ESR --> PUE
ESR --> VM

RP --> SC : fetchSvgDiagram
RP --> ST : preamble / visual

SC --> AB : timeout
SC --> SRV : GET / POST

EXP --> INC
EXP --> SC
EXP --> RP
EXP --> ESR : active doc
EXP --> PUE
EXP ..> CFG : types + getConfig()

legend bottom
  Mesmo grafo que **architecture.puml**; **architecture-overview.puml** para leitura por camadas.
endlegend

@enduml

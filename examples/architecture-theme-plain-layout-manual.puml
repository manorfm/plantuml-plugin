@startuml
' === Variante C: igual ao repo principal architecture.puml ===
' !theme plain + skinparam de layout (nodesep, ranksep, …) →
' o plugin NÃO injecta nodesep/ranksep/linetype automáticos, mas injecta CORES, bordas e estereótipos
' (bloco inserido depois desta linha !theme). shadowing/font/roundcorner abaixo sobrepõem o bloco.
!theme plain
skinparam shadowing false
skinparam roundcorner 10
skinparam defaultFontName Verdana

skinparam nodesep 100
skinparam ranksep 85
skinparam packagePadding 26
skinparam componentPadding 14
skinparam linetype ortho
skinparam ArrowThickness 1

title plantuml-plugin — plain + layout manual (cores do plugin + overrides locais)

left to right direction

package "Entry" {
  component [extension.ts] as EXT <<TypeScript>>
}

package "Utilities" {
  component [abortSignal.ts] as AB
  component [debounce.ts] as DB
}

package "Custom editor" {
  component [plantumlCustomEditorProvider.ts] as CEP
  component [customEditorHtml.ts] as CEH
}

package "Preview (fragments)" {
  component [html.ts] as HTML
}

package "PlantUML / network" {
  component [serverClient.ts] as SC
  component [expandIncludes.ts] as INC
  component [exportDiagram.ts] as EXP
  component [sourceTransform.ts] as ST
}

component [plantumlConfig.ts] as CFG

cloud "PlantUML server\n(HTTP)" as SRV #LightBlue

EXT --> CEP : activate + commands
EXT --> EXP : export

CEP --> CEH : webview
CEP --> INC : !include
CEP --> ST : preamble
CEP --> SC : fetch SVG
CEP --> HTML : HTML mount
CEP --> CFG

EXP --> INC
EXP --> ST
EXP --> SC : media
EXP --> CEP : active doc

SC --> SRV : GET / POST

legend bottom
  Este ficheiro espelha **architecture.puml**: mesmo significado de “plain + layout manual”.
endlegend

@enduml

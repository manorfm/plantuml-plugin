@startuml
' === Variante A: !theme plain + diagrama SEM skinparam de layout ===
' O servidor desenha baseline neutro; a extensão PODE injectar skinparams + SVG
' (plantumlViewer.visualTheme ≠ none, p.ex. modern-dark).
' Copiado de architecture.puml mas sem nodesep/ranksep/paddings/linetype para não bloquear o pipeline.
'
' !theme = motor PlantUML: https://plantuml.com/theme
' Nunca uses aqui: modern-dark, glass, minimal, none (só em Settings).
!theme plain

title plantuml-plugin — plain + pipeline da extensão (pode aplicar)

left to right direction

package "Entry" {
  component [extension.ts] as EXT <<TypeScript>>
}

package "Utilities" {
  component [abortSignal.ts] as AB
  component [debounce.ts] as DB
}

package "Custom editor" {
  component [plantumlCustomEditorProvider.ts] as CEP
  component [customEditorHtml.ts] as CEH
}

package "Preview (fragments)" {
  component [html.ts] as HTML
}

package "PlantUML / network" {
  component [serverClient.ts] as SC
  component [expandIncludes.ts] as INC
  component [exportDiagram.ts] as EXP
  component [sourceTransform.ts] as ST
}

component [plantumlConfig.ts] as CFG

cloud "PlantUML server\n(HTTP)" as SRV #LightBlue

EXT --> CEP : activate + commands
EXT --> EXP : export

CEP --> CEH : webview
CEP --> INC : !include
CEP --> ST : preamble
CEP --> SC : fetch SVG
CEP --> HTML : HTML mount
CEP --> CFG

EXP --> INC
EXP --> ST
EXP --> SC : media
EXP --> CEP : active doc

SC --> SRV : GET / POST

legend bottom
  Compara com **architecture.puml**: lá há nodesep/ranksep/… → pipeline automático desligado.
endlegend

@enduml

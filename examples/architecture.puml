@startuml
!theme plain
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName Verdana

title plantuml-plugin-manorfm v0.10.7 — architecture (this repo)

left to right direction

package "Entry" {
  component [extension.ts] as EXT <<TypeScript>>
}

package "Custom editor" {
  component [plantumlCustomEditorProvider.ts] as CEP
  component [customEditorHtml.ts] as CEH
}

package "Preview (fragments)" {
  component [html.ts] as HTML
}

package "PlantUML / network" {
  component [serverClient.ts] as SC
  component [expandIncludes.ts] as INC
  component [exportDiagram.ts] as EXP
  component [sourceTransform.ts] as ST
}

component [plantumlConfig.ts] as CFG

package "Utilities" {
  component [abortSignal.ts] as AB
  component [debounce.ts] as DB
}

cloud "PlantUML server\n(HTTP)" as SRV #LightBlue

EXT --> CEP : registerCustomEditorProvider\n+ commands
EXT --> EXP : export

CEP --> CEH : webview shell
CEP --> INC : expand !include
CEP --> ST : diagramPreamble
CEP --> SC : fetchSvgDiagram
CEP --> HTML : diagram fragments
CEP --> CFG

EXP --> INC
EXP --> ST
EXP --> SC : SVG / PNG
EXP --> CEP : active document

SC --> SRV : GET (encoded URL)\nor POST (large diagram)

note right of CEP
  **Modes:** code only | code+diagram | diagram only
  Persistence: **plantumlViewer.viewModesByUri** (workspace)
  Same tab; no extra WebviewPanel
end note

note bottom of SRV
  **npm dependency:** plantuml-encoder
  Deflate + base64 encoding
end note

@enduml

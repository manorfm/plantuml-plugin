@startuml
' === Variante B: tema do SERVIDOR PlantUML (não é o visualTheme da extensão) ===
' Estilo vem do motor; a extensão NÃO antepõe o bloco automático de skinparams
' (evita misturar com o tema do servidor).
' Lista: https://plantuml.com/theme
!theme cerulean-outline

title plantuml — cerulean-outline (só servidor)

left to right direction

package "Entry" {
  component [extension.ts] as EXT <<TypeScript>>
}

package "Utilities" {
  component [abortSignal.ts] as AB
  component [debounce.ts] as DB
}

package "Custom editor" {
  component [plantumlCustomEditorProvider.ts] as CEP
  component [customEditorHtml.ts] as CEH
}

package "Preview (fragments)" {
  component [html.ts] as HTML
}

package "PlantUML / network" {
  component [serverClient.ts] as SC
  component [expandIncludes.ts] as INC
  component [exportDiagram.ts] as EXP
  component [sourceTransform.ts] as ST
}

component [plantumlConfig.ts] as CFG

cloud "PlantUML server\n(HTTP)" as SRV #LightBlue

EXT --> CEP : activate + commands
EXT --> EXP : export

CEP --> CEH : webview
CEP --> INC : !include
CEP --> ST : preamble
CEP --> SC : fetch SVG
CEP --> HTML : HTML mount
CEP --> CFG

EXP --> INC
EXP --> ST
EXP --> SC : media
EXP --> CEP : active doc

SC --> SRV : GET / POST

legend bottom
  Troca **cerulean-outline** por outro nome da lista oficial (ex.: **metal**, **materia**) e re-renderiza.
endlegend

@enduml
